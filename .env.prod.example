# ═══════════════════════════════════════════════════════════════════
# SkinAI - AWS 프로덕션 환경변수
# cp .env.prod.example .env.prod  →  값 입력 후 사용
# ⚠  .env.prod 는 절대 git에 커밋하지 마세요
# ═══════════════════════════════════════════════════════════════════

# ─── JWT ────────────────────────────────────────────────────────
# EC2에서 생성: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=14d

# ─── RDS (MySQL 8.0) ────────────────────────────────────────────
# AWS 콘솔 → RDS → 데이터베이스 선택 → 엔드포인트 복사
DB_HOST=<식별자>.xxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=

# ─── AWS S3 ─────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=

# 대학 계정 등 IAM 액세스 키 발급이 불가한 경우 아래 두 항목은 비워두세요.
# EC2에 S3 권한이 있는 IAM 역할이 연결되어 있으면 자동으로 인증됩니다.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Naver API ──────────────────────────────────────────────────
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NAVER_HOSPITAL_SEARCH_KEYWORD=피부과
NAVER_HOSPITAL_SEARCH_DISPLAY=5
