# ═══════════════════════════════════════════════════════════════════
# SkinAI - AWS 프로덕션 환경변수
# cp .env.prod.example .env.prod  →  값 입력 후 사용
# ⚠  .env.prod 는 절대 git에 커밋하지 마세요
# ═══════════════════════════════════════════════════════════════════

# ─── JWT ────────────────────────────────────────────────────────
# 충분히 긴 랜덤 문자열 (openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=14d

# ─── RDS (MySQL 8.0) ────────────────────────────────────────────
# AWS RDS 콘솔 > 엔드포인트 복사
DB_HOST=<rds-endpoint>.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=

# ─── AWS S3 ─────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=

# EC2 IAM 역할을 사용하는 경우 아래 두 항목은 비워두세요
# (IAM 역할이 없는 경우에만 액세스 키를 사용하세요)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Naver API ──────────────────────────────────────────────────
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NAVER_HOSPITAL_SEARCH_KEYWORD=피부과
NAVER_HOSPITAL_SEARCH_DISPLAY=5
