FROM node:20-alpine

WORKDIR /app

# pnpm нҷңм„ұнҷ” (mobilewebмқҖ pnpm-lock.yaml мӮ¬мҡ©)
RUN corepack enable && corepack prepare pnpm@latest --activate

# мқҳмЎҙм„ұ лЁјм Җ м„Өм№ҳ
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --no-frozen-lockfile

# мҶҢмҠӨ ліөмӮ¬
COPY . .

EXPOSE 3000

# Next dev м„ңлІ„ - 0.0.0.0 л°”мқёл”© н•„мҲҳ (лҸ„м»Ө мҷёл¶Җм—җм„ң м ‘к·ј)
CMD ["pnpm", "dev", "-H", "0.0.0.0", "-p", "3000"]
